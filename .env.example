# MCP Farm — environment variable template
# Copy this file to .env and populate all values.
# .env is never committed. This file is committed.
# All values shown as <description> are placeholders — replace with real values.

# ---------------------------------------------------------------------------
# GCP configuration
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=<your-gcp-sandbox-project-id>
GCP_REGION=<gcp-region-e.g.-us-central1>
GCP_ZONE=<gcp-zone-e.g.-us-central1-a>

# ---------------------------------------------------------------------------
# GKE cluster
# ---------------------------------------------------------------------------
GKE_CLUSTER_NAME=mcp-farm-sandbox
GKE_NAMESPACE=mcp-farm
GKE_NODE_MACHINE_TYPE=<resolve-Q6-confirm-with-Lakshman>
GKE_NODE_COUNT=<resolve-Q6-confirm-with-Lakshman>

# ---------------------------------------------------------------------------
# IBM ContextForge container image
# Resolve Q1: confirm image URI and entitlement key with Kashyap or IBM docs.
# ---------------------------------------------------------------------------
CF_IMAGE_URI=<resolve-Q1-ibm-contextforge-image-uri>
CF_IMAGE_TAG=<resolve-Q1-ibm-contextforge-image-tag>
CF_GATEWAY_PORT=8080
CF_REGISTRY_PORT=8081
# Must be true — root cause of Cloud Run failure (2026-05-20). See doc/ADR/ADR-001.
CF_EXPOSE_CONTAINER_PORT=true

# ---------------------------------------------------------------------------
# Cloud SQL (PostgreSQL 15)
# ---------------------------------------------------------------------------
CLOUDSQL_INSTANCE_NAME=mcp-farm-pg
CLOUDSQL_DATABASE_NAME=contextforge
CLOUDSQL_USER=<db-username>
CLOUDSQL_PASSWORD=<db-password>
CLOUDSQL_CONNECTION_STRING=<host:5432/contextforge>

# ---------------------------------------------------------------------------
# Cloud Memorystore (Redis 7)
# ---------------------------------------------------------------------------
MEMORYSTORE_INSTANCE_NAME=mcp-farm-redis
REDIS_HOST=<redis-host>
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Local Docker Compose overrides
# These override the GCP values when running the local stack.
# ---------------------------------------------------------------------------
LOCAL_POSTGRES_PORT=5432
LOCAL_REDIS_PORT=6379
LOCAL_CF_GATEWAY_PORT=8080
LOCAL_CF_REGISTRY_PORT=8081

# ---------------------------------------------------------------------------
# IBM entitlement key (image pull secret for icr.io)
# Resolve Q1.
# ---------------------------------------------------------------------------
IBM_ENTITLEMENT_KEY=<resolve-Q1-ibm-entitlement-key>

# ---------------------------------------------------------------------------
# GitLab MCP (OAuth 2.0)
# Resolve Q4: confirm whether GitLab requires static or dynamic OAuth registration.
# ---------------------------------------------------------------------------
GITLAB_MCP_URL=<gitlab-mcp-endpoint-url>
GITLAB_OAUTH_CLIENT_ID=<resolve-Q4-gitlab-oauth-client-id>
GITLAB_OAUTH_CLIENT_SECRET=<resolve-Q4-gitlab-oauth-client-secret>

# ---------------------------------------------------------------------------
# Virtual server
# ---------------------------------------------------------------------------
VIRTUAL_SERVER_NAME=test-virtual-server

# ---------------------------------------------------------------------------
# Test configuration
# TEST_TARGET: 'local' (Docker Compose) or 'gke' (GKE cluster)
# ---------------------------------------------------------------------------
TEST_SYNTHETIC_DATA_SEED=42
TEST_TARGET=local
TEST_GATEWAY_BASE_URL=http://localhost:8080
TEST_REGISTRY_BASE_URL=http://localhost:8081
